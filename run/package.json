{
  "name": "restyled-run",
  "version": "0.0.0",
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && ncc build lib/main.js && sed -i 's/\\x0D$//' ./dist/index.js",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "test": "vitest run",
    "lint": "eslint",
    "readme": "npx action-docs -u && prettier --write README.md"
  },
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@types/temp": "^0.9.4",
    "action-docs": "^2.5.1",
    "temp": "^0.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^26.0.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
